NODE_ENV=development
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
PROXY_PORT=8080
PORT=8080

# Configuração do Banco PostgreSQL LOCAL
DB_DIALECT=postgres
DB_HOST=db_postgres
DB_PORT=5432
DB_USER=local_user
DB_PASS=local123
DB_NAME=codatende_local
DB_DEBUG=true

# JWT Secrets (para desenvolvimento local)
JWT_SECRET=LOCAL_JWT_SECRET_123456789
JWT_REFRESH_SECRET=LOCAL_REFRESH_SECRET_987654321

# Redis Configuration LOCAL
REDIS_URI=redis://:redis123@cache:6379
REDIS_PORT=6379
REDIS_PASS=redis123
REDIS_DBS=16
REDIS_OPT_LIMITER_MAX=10
REDIS_OPT_LIMITER_DURATION=1000

# Limites para desenvolvimento
USER_LIMIT=100
CONNECTIONS_LIMIT=1000
CLOSED_SEND_BY_ME=true

# Email Configuration (opcional para desenvolvimento)
MAIL_HOST=smtp.gmail.com
MAIL_USER=seu@email.com
MAIL_PASS=sua_senha
MAIL_FROM=seu@email.com
MAIL_PORT=587

# Gerencianet (opcional para desenvolvimento)
GERENCIANET_SANDBOX=true
GERENCIANET_CLIENT_ID=client_id_teste
GERENCIANET_CLIENT_SECRET=client_secret_teste
GERENCIANET_PIX_CERT=certificado_teste
GERENCIANET_PIX_KEY=chave_pix_teste